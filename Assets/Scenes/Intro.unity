  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0c6ca70eb4666324a9e9eed7803d4a78, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  dialoguePanel: {fileID: 655460136}
  dialogueText: {fileID: 555945962}
  nameText: {fileID: 1287507928}
  darkOverlay: {fileID: 320925303}
  sceneTransition: {fileID: 858856559}
  lines:
  - speakerName: "\u0E1C\u0E39\u0E49\u0E08\u0E31\u0E14\u0E01\u0E32\u0E23"
    text: "\u0E40\u0E2E\u0E49\u0E22\u0E44\u0E2D\u0E41\u0E21\u0E27... \u0E40\u0E21\u0E37\u0E48\u0E2D\u0E01\u0E35\u0E49\u0E21\u0E36\u0E07\u0E01\u0E23\u0E30\u0E42\u0E14\u0E14\u0E25\u0E07\u0E21\u0E32\u0E17\u0E48\u0E32\u0E44\u0E2B\u0E19\u0E27\u0E30?
      \u0E40\u0E2B\u0E21\u0E37\u0E2D\u0E19\u0E01\u0E23\u0E30\u0E2A\u0E2D\u0E1A\u0E02\u0E49\u0E32\u0E27\u0E2A\u0E32\u0E23\u0E23\u0E48\u0E27\u0E07\u0E43\u0E2A\u0E48\u0E1E\u0E37\u0E49\u0E19\u0E40\u0E25\u0E22\u0E27\u0E48\u0E30
      \u0E2A\u0E20\u0E32\u0E1E\u0E41\u0E01\u0E15\u0E2D\u0E19\u0E19\u0E35\u0E49\u0E16\u0E49\u0E32\u0E2A\u0E48\u0E07\u0E44\u0E1B\u0E40\u0E25\u0E48\u0E19\u0E2B\u0E19\u0E31\u0E07\u0E1C\u0E35\u0E2A\u0E22\u0E2D\u0E07\u0E02\u0E27\u0E31\u0E0D\u0E04\u0E07\u0E44\u0E21\u0E48\u0E15\u0E49\u0E2D\u0E07\u0E41\u0E15\u0E48\u0E07\u0E2B\u0E19\u0E49\u0E32\u0E41\u0E25\u0E49\u0E27"
    speakerImage: {fileID: 1500454855}
  - speakerName: "\u0E41\u0E21\u0E27"
    text: "\u0E40\u0E2D\u0E2D... \u0E40\u0E02\u0E48\u0E32\u0E01\u0E39\u0E1E\u0E31\u0E07
      \u0E15\u0E32\u0E1E\u0E25\u0E32\u0E22... \u0E01\u0E39\u0E27\u0E48\u0E32\u0E01\u0E39\u0E44\u0E21\u0E48\u0E44\u0E2B\u0E27\u0E41\u0E25\u0E49\u0E27\u0E27\u0E48\u0E30\u0E1E\u0E35\u0E48\u0E2B\u0E21\u0E35"
    speakerImage: {fileID: 1066417145}
  - speakerName: "\u0E2B\u0E21\u0E35"
    text: "\u0E40\u0E2D\u0E2D \u0E23\u0E39\u0E49\u0E41\u0E25\u0E49\u0E27! \u0E02\u0E37\u0E19\u0E21\u0E36\u0E07\u0E15\u0E32\u0E22\u0E04\u0E32\u0E01\u0E2D\u0E07\u0E16\u0E48\u0E32\u0E22
      \u0E1B\u0E23\u0E30\u0E01\u0E31\u0E19\u0E44\u0E21\u0E48\u0E08\u0E48\u0E32\u0E22\u0E01\u0E39\u0E0B\u0E27\u0E22\u0E2D\u0E35\u0E01\u0E40\u0E19\u0E35\u0E48\u0E22
      \u0E15\u0E31\u0E4B\u0E27\u0E40\u0E23\u0E37\u0E2D\u0E2A\u0E33\u0E23\u0E32\u0E0D\u0E19\u0E35\u0E48\u0E21\u0E36\u0E07\u0E40\u0E2D\u0E32\u0E44\u0E1B\u0E0B\u0E30
      \u0E44\u0E1B\u0E19\u0E2D\u0E19\u0E2D\u0E37\u0E14\u0E40\u0E1B\u0E47\u0E19\u0E28\u0E1E\u0E23\u0E34\u0E21\u0E2B\u0E32\u0E14\u0E2A\u0E31\u0E01\u0E40\u0E14\u0E37\u0E2D\u0E19
      \u0E40\u0E1C\u0E37\u0E48\u0E2D\u0E40\u0E04\u0E23\u0E37\u0E48\u0E2D\u0E07\u0E40\u0E04\u0E23\u0E32\u0E08\u0E30\u0E01\u0E25\u0E31\u0E1A\u0E21\u0E32\u0E15\u0E34\u0E14\u0E2D\u0E35\u0E01\u0E23\u0E2D\u0E1A"
    speakerImage: {fileID: 1126808944}
  interactHint: {fileID: 1477730831}
