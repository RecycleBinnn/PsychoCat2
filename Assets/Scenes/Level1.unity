  - speakerName: "\u0E41\u0E21\u0E27"
    text: "\u0E44\u0E21\u0E48\u0E23\u0E39\u0E49\u0E14\u0E34\u0E41\u0E15\u0E48\u0E01\u0E47\u0E19\u0E35\u0E49\u0E21\u0E31\u0E19\u0E40\u0E01\u0E21\u0E41\u0E19\u0E27
