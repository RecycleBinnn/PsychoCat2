--- !u!114 &2106133678
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2106133677}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4930f4b9e1340b1429227df81bb6409f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogueNormal
  dialoguePanel: {fileID: 315488971}
  dialogueText: {fileID: 1444480446}
  nameText: {fileID: 949095370}
  darkOverlay: {fileID: 745333324}
  lines:
  - speakerName: "\u0E41\u0E21\u0E27"
    text: "\u0E01\u0E25\u0E34\u0E48\u0E19\u0E02\u0E35\u0E49\u0E2B\u0E19\u0E39\u0E41\u0E23\u0E07\u0E09\u0E34\u0E1A\u0E2B\u0E32\u0E22
      \u0E19\u0E35\u0E48\u0E01\u0E39\u0E02\u0E36\u0E49\u0E19\u0E40\u0E23\u0E37\u0E2D\u0E16\u0E39\u0E01\u0E25\u0E33\u0E41\u0E19\u0E48\u0E40\u0E2B\u0E23\u0E2D
      \u0E2B\u0E23\u0E37\u0E2D\u0E1E\u0E35\u0E48\u0E2B\u0E21\u0E35\u0E21\u0E31\u0E19\u0E2B\u0E25\u0E2D\u0E01\u0E01\u0E39\u0E21\u0E32\u0E16\u0E48\u0E32\u0E22\u0E2B\u0E19\u0E31\u0E07\u0E41\u0E25\u0E49\u0E27\u0E44\u0E21\u0E48\u0E1A\u0E2D\u0E01\u0E04\u0E48\u0E32\u0E15\u0E31\u0E27\u0E27\u0E30?"
    speakerImage: {fileID: 575330227}
  - speakerName: "\u0E25\u0E38\u0E07\u0E2B\u0E19\u0E39"
    text: "\u0E02\u0E49\u0E32\u0E0A\u0E37\u0E48\u0E2D \u0E2B\u0E19\u0E39... \u0E41\u0E25\u0E30\u0E19\u0E35\u0E48\u0E44\u0E21\u0E48\u0E43\u0E0A\u0E48\u0E2B\u0E19\u0E31\u0E07
      \u0E44\u0E2D\u0E49\u0E2B\u0E19\u0E38\u0E48\u0E21 \u0E41\u0E01\u0E02\u0E36\u0E49\u0E19\u0E40\u0E23\u0E37\u0E2D\u0E1C\u0E34\u0E14\u0E25\u0E33\u0E41\u0E25\u0E49\u0E27
      \u0E19\u0E35\u0E48\u0E21\u0E31\u0E19\u0E40\u0E23\u0E37\u0E2D\u0E02\u0E19\u0E17\u0E32\u0E2A\u0E44\u0E1B\u0E40\u0E01\u0E32\u0E30\u0E19\u0E23\u0E01"
    speakerImage: {fileID: 742770238}
  - speakerName: "\u0E25\u0E38\u0E07\u0E2B\u0E19\u0E39"
    text: "\u0E40\u0E2E\u0E49 \u0E43\u0E19\u0E17\u0E35\u0E48\u0E2A\u0E38\u0E14\u0E21\u0E36\u0E07\u0E01\u0E47\u0E15\u0E37\u0E48\u0E19\u0E2A\u0E31\u0E01\u0E17\u0E35\u0E16\u0E49\u0E32\u0E08\u0E30\u0E08\u0E2D\u0E07\u0E17\u0E35\u0E48\u0E1D\u0E31\u0E07\u0E28\u0E1E\u0E25\u0E48\u0E30\u0E01\u0E47
      \u0E43\u0E08\u0E40\u0E22\u0E47\u0E19 \u0E46 \u0E2D\u0E35\u0E01\u0E40\u0E14\u0E35\u0E4B\u0E22\u0E27\u0E1E\u0E27\u0E01\u0E1C\u0E39\u0E49\u0E04\u0E38\u0E21\u0E21\u0E31\u0E19\u0E01\u0E47\u0E21\u0E32\u0E25\u0E32\u0E01\u0E21\u0E36\u0E07\u0E44\u0E1B\u0E17\u0E33\u0E1B\u0E38\u0E4B\u0E22\u0E17\u0E35\u0E48\u0E40\u0E01\u0E32\u0E30\u0E41\u0E25\u0E49\u0E27"
    speakerImage: {fileID: 742770238}
  - speakerName: "\u0E41\u0E21\u0E27"
    text: " \"\u0E40\u0E01\u0E32\u0E30\u0E40\u0E2B\u0E23\u0E2D? \u0E01\u0E39\u0E19\u0E36\u0E01\u0E27\u0E48\u0E32\u0E01\u0E39\u0E08\u0E30\u0E44\u0E14\u0E49\u0E19\u0E2D\u0E19\u0E1A\u0E38\u0E1F\u0E40\u0E1F\u0E15\u0E4C\u0E40\u0E23\u0E37\u0E2D\u0E2A\u0E33\u0E23\u0E32\u0E0D\u0E0B\u0E30\u0E2D\u0E35\u0E01
      \u0E0A\u0E35\u0E27\u0E34\u0E15\u0E01\u0E39\u0E19\u0E35\u0E48\u0E21\u0E31\u0E19\u0E15\u0E25\u0E01\u0E23\u0E49\u0E32\u0E22\u0E09\u0E34\u0E1A\u0E2B\u0E32\u0E22\""
    speakerImage: {fileID: 575330227}
  - speakerName: "\u0E25\u0E38\u0E07\u0E2B\u0E19\u0E39"
    text: "\u0E15\u0E25\u0E01\u0E01\u0E27\u0E48\u0E32\u0E19\u0E31\u0E49\u0E19\u0E04\u0E37\u0E2D\u0E04\u0E19\u0E02\u0E49\u0E32\u0E07\u0E2B\u0E49\u0E2D\u0E07\u0E21\u0E36\u0E07\u0E40\u0E19\u0E35\u0E48\u0E22\u0E41\u0E2B\u0E25\u0E30...
      \u0E01\u0E39\u0E40\u0E2B\u0E47\u0E19\u0E19\u0E30\u0E27\u0E48\u0E32\u0E21\u0E36\u0E07\u0E41\u0E2D\u0E1A\u0E2B\u0E22\u0E34\u0E21\u0E02\u0E19\u0E21\u0E1B\u0E31\u0E07\u0E1C\u0E39\u0E49\u0E04\u0E38\u0E21\u0E21\u0E32\u0E01\u0E39\u0E14\u0E39\u0E17\u0E48\u0E32\u0E17\u0E32\u0E07\u0E21\u0E36\u0E07\u0E40\u0E2B\u0E21\u0E37\u0E2D\u0E19\u0E04\u0E19\u0E40\u0E04\u0E22\u0E21\u0E35\u0E02\u0E2D\u0E07\u0E19\u0E30
      \u0E16\u0E49\u0E32\u0E44\u0E21\u0E48\u0E2D\u0E22\u0E32\u0E01\u0E40\u0E1B\u0E47\u0E19\u0E02\u0E35\u0E49\u0E40\u0E16\u0E49\u0E32\u0E40\u0E23\u0E47\u0E27\u0E44\u0E1B
      \u0E25\u0E2D\u0E07\u0E2A\u0E30\u0E40\u0E14\u0E32\u0E30\u0E01\u0E25\u0E2D\u0E19\u0E01\u0E23\u0E07\u0E19\u0E31\u0E48\u0E19\u0E14\u0E39\u0E44\u0E2B\u0E21?"
    speakerImage: {fileID: 742770238}
  - speakerName: "\u0E41\u0E21\u0E27"
    text: "\u0E2B\u0E36... \u0E2A\u0E30\u0E40\u0E14\u0E32\u0E30\u0E01\u0E25\u0E2D\u0E19\u0E40\u0E2B\u0E23\u0E2D?
      \u0E40\u0E21\u0E37\u0E48\u0E2D\u0E01\u0E48\u0E2D\u0E19\u0E01\u0E39\u0E17\u0E33\u0E43\u0E19\u0E2B\u0E19\u0E31\u0E07\u0E20\u0E32\u0E22\u0E43\u0E19
      5 \u0E27\u0E34\u0E19\u0E32\u0E17\u0E35\u0E19\u0E30\u0E25\u0E38\u0E07... \u0E04\u0E23\u0E32\u0E27\u0E19\u0E35\u0E49\u0E02\u0E2D\u0E2A\u0E31\u0E01
      10 \u0E41\u0E25\u0E49\u0E27\u0E01\u0E31\u0E19 \u0E01\u0E23\u0E30\u0E14\u0E39\u0E01\u0E19\u0E34\u0E49\u0E27\u0E21\u0E31\u0E19\u0E1D\u0E37\u0E14\u0E27\u0E48\u0E30"
    speakerImage: {fileID: 575330227}
  - speakerName: "\u0E41\u0E21\u0E27"
    text: "\u0E41\u0E25\u0E49\u0E27\u0E40\u0E23\u0E32\u0E08\u0E30\u0E44\u0E1B\u0E44\u0E2B\u0E19\u0E15\u0E48\u0E2D\u0E27\u0E30\u0E25\u0E38\u0E07"
    speakerImage: {fileID: 575330227}
  - speakerName: "\u0E25\u0E38\u0E07\u0E2B\u0E19\u0E39"
    text: "\u0E01\u0E39\u0E44\u0E14\u0E49\u0E22\u0E34\u0E19\u0E04\u0E19\u0E1E\u0E39\u0E14\u0E01\u0E31\u0E19\u0E21\u0E32\u0E27\u0E48\u0E32\u0E21\u0E35\u0E40\u0E2A\u0E37\u0E2D\u0E42\u0E14\u0E19\u0E08\u0E31\u0E1A\u0E02\u0E31\u0E07\u0E2D\u0E22\u0E39\u0E48\u0E17\u0E35\u0E48\u0E02\u0E38\u0E14\u0E41\u0E23\u0E48\u0E40\u0E1E\u0E23\u0E32\u0E30\u0E27\u0E32\u0E07\u0E41\u0E1C\u0E19\u0E2B\u0E19\u0E35\u0E16\u0E49\u0E32\u0E1E\u0E27\u0E01\u0E40\u0E23\u0E32\u0E08\u0E30\u0E2B\u0E19\u0E35\u0E01\u0E31\u0E19\u0E01\u0E39\u0E27\u0E48\u0E32\u0E15\u0E49\u0E2D\u0E07\u0E44\u0E1B\u0E2B\u0E32\u0E15\u0E31\u0E27\u0E44\u0E2D\u0E40\u0E2A\u0E37\u0E2D\u0E19\u0E31\u0E49\u0E19\u0E01\u0E48\u0E2D\u0E19"
    speakerImage: {fileID: 742770238}
  - speakerName: "\u0E41\u0E21\u0E27"
    text: "\u0E44\u0E14\u0E49\u0E14\u0E34\u0E25\u0E38\u0E07\u0E15\u0E32\u0E21\u0E1C\u0E21\u0E21\u0E32\u0E40\u0E25\u0E22\u0E40\u0E14\u0E35\u0E4B\u0E22\u0E27\u0E1C\u0E21\u0E1E\u0E32\u0E44\u0E1B\u0E40\u0E2D\u0E07"
    speakerImage: {fileID: 575330227}
  - speakerName: "\u0E25\u0E38\u0E07\u0E2B\u0E19\u0E39"
    text: "\u0E21\u0E36\u0E07\u0E23\u0E39\u0E49\u0E17\u0E32\u0E07\u0E44\u0E1B\u0E2B\u0E23\u0E2D\u0E27\u0E30"
