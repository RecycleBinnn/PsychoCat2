  m_Script: {fileID: 11500000, guid: 4930f4b9e1340b1429227df81bb6409f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogueNormal
  dialoguePanel: {fileID: 657941690}
  dialogueText: {fileID: 1214227982}
  nameText: {fileID: 542666866}
  darkOverlay: {fileID: 1344412846}
  lines:
  - speakerName: "\u0E08\u0E34\u0E49\u0E07\u0E08\u0E2D\u0E01"
    text: "\u0E44\u0E2D\u0E40\u0E2A\u0E37\u0E2D\u0E2D\u0E2D \u0E01\u0E39\u0E2D\u0E22\u0E38\u0E48\u0E19\u0E35\u0E49!"
    speakerImage: {fileID: 1011537010}
  - speakerName: "\u0E40\u0E2A\u0E37\u0E2D"
    text: "\u0E01\u0E39\u0E1E\u0E32\u0E04\u0E19\u0E21\u0E32\u0E0B\u0E2D\u0E22\u0E21\u0E36\u0E07\u0E41\u0E25\u0E49\u0E27\u0E40\u0E14\u0E49\u0E2D
      \u0E1A\u0E31\u0E01\u0E08\u0E2D\u0E01!"
    speakerImage: {fileID: 152816158}
  - speakerName: "\u0E08\u0E34\u0E49\u0E07\u0E08\u0E2D\u0E01"
    text: "\u0E02\u0E2D\u0E1A\u0E04\u0E38\u0E13\u0E04\u0E23\u0E31\u0E1A\u0E1E\u0E35\u0E48..."
    speakerImage: {fileID: 1011537010}
  - speakerName: "\u0E41\u0E21\u0E27"
    text: "\u0E01\u0E39\u0E0A\u0E37\u0E48\u0E2D\u0E41\u0E21\u0E27"
    speakerImage: {fileID: 1097129220}
  - speakerName: "\u0E08\u0E34\u0E49\u0E07\u0E08\u0E2D\u0E01"
    text: "\u0E02\u0E2D\u0E1A\u0E04\u0E38\u0E13\u0E04\u0E23\u0E31\u0E1A\u0E1E\u0E35\u0E48\u0E41\u0E21\u0E27\u0E15\u0E2D\u0E19\u0E19\u0E35\u0E49\u0E1C\u0E21\u0E15\u0E34\u0E14\u0E15\u0E48\u0E2D\u0E04\u0E19\u0E19\u0E2D\u0E01\u0E40\u0E01\u0E32\u0E30\u0E44\u0E14\u0E49\u0E41\u0E25\u0E49\u0E27\u0E41\u0E15\u0E48\u0E15\u0E49\u0E2D\u0E07\u0E44\u0E1B\u0E1B\u0E34\u0E14\u0E23\u0E30\u0E1A\u0E1A\u0E1B\u0E31\u0E07\u0E2A\u0E31\u0E0D\u0E13\u0E32\u0E13\u0E17\u0E35\u0E48\u0E2B\u0E49\u0E2D\u0E07\u0E1A\u0E2D\u0E2A\u0E01\u0E48\u0E2D\u0E19\u0E16\u0E36\u0E07\u0E08\u0E30\u0E2A\u0E48\u0E07\u0E1E\u0E34\u0E01\u0E31\u0E14\u0E40\u0E01\u0E32\u0E30\u0E44\u0E14\u0E49"
    speakerImage: {fileID: 1011537010}
  - speakerName: "\u0E41\u0E21\u0E27"
    text: "\u0E07\u0E31\u0E49\u0E19\u0E23\u0E35\u0E1A\u0E44\u0E1B\u0E01\u0E31\u0E19\u0E40\u0E16\u0E2D\u0E30"
    speakerImage: {fileID: 1097129220}
  - speakerName: "\u0E08\u0E34\u0E49\u0E07\u0E08\u0E2D\u0E01"
    text: "\u0E40\u0E14\u0E35\u0E4B\u0E22\u0E27\u0E1E\u0E35\u0E48\u0E1E\u0E35\u0E48\u0E40\u0E2B\u0E22\u0E35\u0E22\u0E1A\u0E14\u0E31\u0E1A\u0E23\u0E30\u0E40\u0E1A\u0E34\u0E14\u0E2D\u0E22\u0E39\u0E48!!!!!!"
    speakerImage: {fileID: 1011537010}
  - speakerName: "\u0E41\u0E21\u0E27"
    text: ...
    speakerImage: {fileID: 1097129220}
  - speakerName: "\u0E08\u0E34\u0E49\u0E07\u0E08\u0E2D\u0E01"
    text: "\u0E44\u0E21\u0E48\u0E21\u0E35\u0E44\u0E23\u0E2B\u0E23\u0E2D\u0E1C\u0E21\u0E42\u0E21\u0E49\u0E1E\u0E35\u0E48\u0E40\u0E25\u0E48\u0E19\u0E40\u0E09\u0E22\u0E46
      \u0E43\u0E08\u0E2B\u0E32\u0E22\u0E40\u0E25\u0E22\u0E14\u0E34\u0E01\u0E25\u0E31\u0E27\u0E44\u0E14\u0E49\u0E40\u0E25\u0E48\u0E19\u0E43\u0E2B\u0E21\u0E48\u0E40\u0E25\u0E22\u0E14\u0E34\u0E49555555555"
    speakerImage: {fileID: 1011537010}
  - speakerName: "\u0E41\u0E21\u0E27"
    text: "\u0E2B\u0E31\u0E27\u0E40\u0E23\u0E32\u0E30\u0E44\u0E1B\u0E46  \u0E40\u0E14\u0E35\u0E4B\u0E22\u0E27\u0E2A\u0E16\u0E32\u0E19\u0E30\u0E01\u0E32\u0E23\u0E08\u0E23\u0E34\u0E07\u0E08\u0E30\u0E2B\u0E31\u0E27\u0E40\u0E23\u0E32\u0E30\u0E44\u0E21\u0E48\u0E2D\u0E2D\u0E01\r\n"
    speakerImage: {fileID: 1097129220}
  interactHint: {fileID: 324014600}
